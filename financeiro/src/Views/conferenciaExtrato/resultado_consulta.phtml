<?php
    use MF\Helpers\DateHelper;
    use MF\Helpers\NumbersHelper;

    $ids_ja_salvos = [];
    $registros_conferidos_map = [];
    foreach ($registros_conferidos as $reg) {
        $ids_ja_salvos[$reg['idMovimento']] = true;
        $registros_conferidos_map[$reg['idMovimento']] = $reg;
    }

    $extra_conferidos = 0;
    foreach ($registros_conferidos as $reg) {
        if (!isset($ids_conferidos[$reg['idMovimento']])) {
            $extra_conferidos++;
        }
    }
    $total_conferidos_combinado = $extra_conferidos;
    $total_extrato_combinado    = count($registros_conferidos);
    $percentual_combinado       = round(($total_conferidos_combinado) * 100, 1);
?>

