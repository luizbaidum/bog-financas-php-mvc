<?php
    use MF\Helpers\DateHelper;
    use MF\Helpers\NumbersHelper;

    $ids_conferidos = [];
    foreach ($resultado['conferidos'] as $conf) {
        $id_movimento = $conf['sistema']['idMovimento'];
        $ids_conferidos[$id_movimento] = true;
        $json[$id_movimento] = json_encode($conf['extrato']);
    }

    $ids_ja_salvos = [];
    foreach ($registros_conferidos as $reg) {
        $ids_ja_salvos[$reg['idMovimento']] = true;
    }

    $resumo = $resultado['resumo'];

    // Totais combinados: processa atual + registros já salvos de outros bancos
    $extra_conferidos = 0;
    foreach ($registros_conferidos as $reg) {
        if (!isset($ids_conferidos[$reg['idMovimento']])) {
            $extra_conferidos++;
        }
    }
    $total_conferidos_combinado = $resumo['total_conferidos'] + $extra_conferidos;
    $total_extrato_combinado    = $resumo['total_extrato'] + count($registros_conferidos);
    $percentual_combinado       = $resumo['total_sistema'] > 0
        ? round(($total_conferidos_combinado / $resumo['total_sistema']) * 100, 1)
        : 0;
?>

<div class="py-3">
    <div class="row row-cols-1 row-cols-md-4 g-3 mb-4">
        <div class="col">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-3">
                    <div class="fs-4 fw-bold text-primary"><?= $total_conferidos_combinado ?></div>
                    <div class="small text-muted">Conferidos</div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-3">
                    <div class="fs-4 fw-bold text-secondary"><?= $resumo['total_sistema'] ?></div>
                    <div class="small text-muted">No sistema</div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-3">
                    <div class="fs-4 fw-bold text-secondary"><?= $total_extrato_combinado ?></div>
                    <div class="small text-muted">No extrato</div>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card border-0 shadow-sm text-center">
                <div class="card-body py-3">
                    <div class="fs-4 fw-bold <?= $percentual_combinado >= 90 ? 'text-success' : ($percentual_combinado >= 60 ? 'text-warning' : 'text-danger') ?>">
                        <?= $percentual_combinado ?>%
                    </div>
                    <div class="small text-muted">Conferência</div>
                </div>
            </div>
        </div>
    </div>

    <form data-action="<?= $action2; ?>" class="submit-form-crud-ajax">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header d-flex justify-content-between align-items-center py-2 bg-white">
                <span class="fw-semibold"><i class="bi bi-check2-circle me-1"></i>Movimentos do Sistema</span>
                <span class="badge bg-success"><?= $total_conferidos_combinado ?> encontrados</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm mb-0 align-middle">
                        <thead>
                            <tr>
                                <th class="text-uppercase small text-muted">ID</th>
                                <th class="text-uppercase small text-muted">Data</th>
                                <th class="text-uppercase small text-muted">Movimento</th>
                                <th class="text-uppercase small text-muted">Categoria</th>
                                <th class="text-uppercase small text-muted">Valor</th>
                                <th class="text-uppercase small text-muted">Proprietário</th>
                                <th class="text-uppercase small text-muted text-center" style="width: 5%;">Conf.</th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php if (empty($movimentos)): ?>
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">Nenhum movimento encontrado para o período.</td>
                                </tr>
                            <?php else: ?>
                                <?php foreach ($movimentos as $mov):
                                    $conferido   = isset($ids_conferidos[$mov['idMovimento']]);
                                    $ja_salvo    = isset($ids_ja_salvos[$mov['idMovimento']]);
                                    $row_class   = ($conferido || $ja_salvo) ? 'table-success' : '';
                                ?>
                                    <tr class="<?= $row_class ?>">
                                        <td><?= $mov['idMovimento'] ?></td>
                                        <td><?= DateHelper::convertUStoBR($mov['dataMovimento']) ?></td>
                                        <td><?= $mov['nomeMovimento'] ?></td>
                                        <td><?= $mov['categoria'] ?></td>
                                        <td class="fw-semibold">R$ <?= NumbersHelper::formatUStoBR($mov['valor']) ?></td>
                                        <td><?= $mov['proprietario'] ?></td>
                                        <td class="text-center">
                                            <?php if ($ja_salvo): ?>
                                                <input
                                                    class="form-check-input"
                                                    type="checkbox"
                                                    checked
                                                    disabled
                                                    style="pointer-events:none;">
                                            <?php else: ?>
                                                <input 
                                                    class="form-check-input" type="checkbox" 
                                                    name="conferidos[<?= $mov['idMovimento']; ?>]" 
                                                    value='<?= htmlspecialchars($json[$mov['idMovimento']] ?? '', ENT_QUOTES, 'UTF-8'); ?>'
                                                    <?= $conferido ? 'checked' : '' ?>>
                                            <?php endif; ?>
                                        </td>
                                    </tr>
                                <?php endforeach; ?>
                            <?php endif; ?>
                        </tbody>
                    </table>
                </div>

                <button id="salvar" type="submit" class="btn btn-success m-2">Salvar</button>
            </div>
        </div>
    </form>
</div>